# Local browser testing only. Leave empty in any real environment.
#
# Set this to a valid, signed Telegram WebApp initData string (e.g. captured
# from a real Telegram session via @BotFather test bot, or however your team
# generates one) to authenticate API calls when running the Mini App in a
# plain browser instead of inside Telegram. The backend still validates the
# initData signature as usual — this does not bypass auth in any way.
#
# Never commit a real value here. Put it in .env.local instead (gitignored).
VITE_DEV_TMA_INIT_DATA=

# Telegram bot username used by invite/share links. Without @.
VITE_BOT_USERNAME=your_bot_username_without_at
